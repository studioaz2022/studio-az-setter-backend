# ═══════════════════════════════════════════════════════
# Studio AZ Setter Backend — Environment Variables
# ═══════════════════════════════════════════════════════
# For utilization engine testing, you only need:
#   GHL_BARBER_LOCATION_ID, GHL_FILE_UPLOAD_TOKEN, SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY

# ── GoHighLevel (Barbershop Location) ──
GHL_BARBER_LOCATION_ID=GLRkNAxfPtWTqTiN83xj
GHL_FILE_UPLOAD_TOKEN=                          # PIT token (pit-...) — ask Lionel

# ── Supabase ──
SUPABASE_URL=                                    # https://xxx.supabase.co — ask Lionel
SUPABASE_SERVICE_ROLE_KEY=                       # service_role key — ask Lionel

# ── Meta Ads (Marketing API) ──
META_APP_ID=                                     # Studio AZ app: 1712852903196491
META_APP_SECRET=                                 # From developers.facebook.com → app → Settings → Basic
META_ACCESS_TOKEN=                               # Long-lived user token (60d) OR System User token (never expires) — prefer System User for prod
META_AD_ACCOUNT_ID=act_270470901                 # Holds BOTH tattoo and barbershop campaigns
META_BUSINESS_ID=3385896878322413                # Studio AZ Business Manager

# ── Not needed for utilization testing ──
# GHL_API_KEY=                                   # v1 JWT (legacy, unused by SDK)
# GHL_LOCATION_ID=                               # Tattoo shop location
# SQUARE_ACCESS_TOKEN=
# SQUARE_LOCATION_ID=
# SQUARE_SANDBOX_ACCESS_TOKEN=                    # Optional. Set (with the location below) to route TEST-phone deposits to Square SANDBOX so they can be paid with a test card. Apply the checkout_sessions `environment` column migration FIRST.
# SQUARE_SANDBOX_LOCATION_ID=                     # Sandbox location id (Square dashboard → Sandbox → Locations).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# AI_BOT_VERSION=v1                               # AI setter brain: "v1" (default) or "v2" (rewrite). Per-contact override via ai_bot_version custom field.
# AI_BOT_V2_PHONES=                               # Comma-separated test phones forced to v2 (any format; matched by last 10 digits). e.g. 5551234567,5559876543
# AI_BOT_SHADOW=false                             # Phase 0.5: when "true", run v2 funnel gate in shadow mode (logs decisions, changes nothing). Classifier reuses LLM_API_KEY.
# CONSULT_FORM_URL=                               # Phase 2: base URL the v2 send_consult_form_link tool hands out. Unset → tool no-ops gracefully.
# AI_FOLLOWUPS_ENABLED=false                      # Phase 4: when "true", bot can schedule touch-back follow-ups + (with a cron) send them. Default off — feature deferred pending cadence review.
# AI_BUBBLE_DELAY_MS=0                             # ms pause between v2 bubble sends. 0 = fast (testing). Set ~2500 in prod: fixes carrier out-of-order delivery + makes the cadence feel human.
# INSTANT_APP_ADMIN_TOKEN=
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_KEY_PATH=
